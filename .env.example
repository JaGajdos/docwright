# Optional local / Railway env (never commit real secrets)

# --- LLM: Azure OpenAI (Aston) OR public OpenAI ---
OPENAI_API_KEY=
# DOCWRIGHT_LLM_PROVIDER=openai   # openai | azure | openai-compatible

# Azure OpenAI (Aston — Responses API / gpt-5.6-terra):
# AZURE_OPENAI_ENDPOINT=https://aston-hct.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# AZURE_OPENAI_DEPLOYMENT=T1-gpt-5.6-terra
# DOCWRIGHT_LLM_API=responses   # default when AZURE_* set; use chat to force completions

# Public OpenAI only (leave AZURE_* unset):
OPENAI_MODEL=gpt-4o-mini

# Other OpenAI-compatible APIs (Ollama, Groq, …):
# DOCWRIGHT_LLM_PROVIDER=openai-compatible
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=llama3.2
# OPENAI_API_KEY=ollama

GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

# MCP provider (default github — same as today)
# DOCWRIGHT_MCP_PROVIDER=github

DOCWRIGHT_API_KEY=
CORS_ORIGINS=http://localhost:5173,https://YOUR_USER.github.io
PORT=8787
DOCWRIGHT_REQUEST_TIMEOUT_MS=120000

DOCWRIGHT_RATE_LIMIT_PER_HOUR=5
DOCWRIGHT_RATE_LIMIT_PER_DAY=20

# Verbose Railway logs for /v1/generate (MCP + agent rounds)
# DOCWRIGHT_DEBUG=1

# MCP spawn (Dockerfile sets binary + stdio)
# DOCWRIGHT_MCP_COMMAND=/usr/local/bin/github-mcp-server
# DOCWRIGHT_MCP_ARGS=["stdio"]

# MCP tools (get_repository_tree is in `git` toolset)
# GITHUB_TOOLSETS=repos,git
# GITHUB_TOOLS=get_repository_tree,get_file_contents

DOCWRIGHT_OUTPUT_LANGUAGE=en

# Agent behaviour: edit config/agent.json + config/prompts/*.md
# (limits + LLM system/user/final prompts). Env still overrides limits.
# DOCWRIGHT_AGENT_CONFIG=config/agent.json
DOCWRIGHT_MAX_FILES_READ=8
DOCWRIGHT_MAX_TOOL_ROUNDS=8
# DOCWRIGHT_MAX_TOOL_RESULT_CHARS=12000
# DOCWRIGHT_MAX_FILE_TOOLS_PER_ROUND=3
