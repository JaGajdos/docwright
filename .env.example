# Optional local / Railway env (never commit real secrets)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

DOCWRIGHT_API_KEY=
CORS_ORIGINS=http://localhost:5173,https://YOUR_USER.github.io
PORT=8787
DOCWRIGHT_REQUEST_TIMEOUT_MS=120000

DOCWRIGHT_RATE_LIMIT_PER_HOUR=5
DOCWRIGHT_RATE_LIMIT_PER_DAY=20

# MCP spawn (default = docker official image)
# DOCWRIGHT_MCP_COMMAND=github-mcp-server
# DOCWRIGHT_MCP_ARGS=[]

DOCWRIGHT_OUTPUT_LANGUAGE=en
DOCWRIGHT_MAX_FILES_READ=25
DOCWRIGHT_MAX_TOOL_ROUNDS=12
