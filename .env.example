# Optional local / Railway env (never commit real secrets)

# --- LLM: Azure OpenAI (Aston) OR public OpenAI ---
OPENAI_API_KEY=

# Azure OpenAI (set these on Railway for aston-hct):
# AZURE_OPENAI_ENDPOINT=https://aston-hct.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-04-01-preview
# AZURE_OPENAI_DEPLOYMENT=T1-gpt-5.6-terra

# Public OpenAI only (leave AZURE_* unset):
OPENAI_MODEL=gpt-4o-mini

GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

DOCWRIGHT_API_KEY=
CORS_ORIGINS=http://localhost:5173,https://YOUR_USER.github.io
PORT=8787
DOCWRIGHT_REQUEST_TIMEOUT_MS=120000

DOCWRIGHT_RATE_LIMIT_PER_HOUR=5
DOCWRIGHT_RATE_LIMIT_PER_DAY=20

# MCP spawn (Dockerfile sets binary + stdio)
# DOCWRIGHT_MCP_COMMAND=/usr/local/bin/github-mcp-server
# DOCWRIGHT_MCP_ARGS=["stdio"]

# MCP tools (get_repository_tree is in `git` toolset)
# GITHUB_TOOLSETS=repos,git
# GITHUB_TOOLS=get_repository_tree,get_file_contents

DOCWRIGHT_OUTPUT_LANGUAGE=en
DOCWRIGHT_MAX_FILES_READ=25
DOCWRIGHT_MAX_TOOL_ROUNDS=12
